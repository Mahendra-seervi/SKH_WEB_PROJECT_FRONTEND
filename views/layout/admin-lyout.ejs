<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Warden Dashboard - SKH</title>
    <link rel="icon" href="/skh.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/admin.css">
</head>
<body>

    <div class="admin-wrapper">
        <nav id="sidebar">
            <div class="sidebar-header">
                <h3>SKH Admin</h3>
            </div>

            <ul class="list-unstyled components">
                <li class="<%= currentPage === '/admin' ? 'active' : '' %>"><a href="/admin"><i class="fa-solid fa-user-tie"></i> Profile</a></li>
                <li class="<%= currentPage.startsWith('/admin/payments') ? 'active' : '' %>" ><a href="/admin/payments"><i class="fa-solid fa-credit-card"></i> Payments</a></li>
                <li class="<%= currentPage.startsWith('/admin/students') ? 'active' : '' %>"><a href="/admin/students"><i class="fa-solid fa-user-graduate"></i> Students</a></li>
                <li class="<%= currentPage.startsWith('/admin/studentnotice') ? 'active' : '' %>"><a href="/admin/studentnotices"><i class="fa-solid fa-envelope-open-text"></i>student Notices</a> </li>
                <li class="<%= currentPage.startsWith('/admin/rooms') ? 'active' : '' %>"><a href="/admin/rooms"><i class="fa-solid fa-bed"></i> Rooms</a></li>
                <li class="<%= currentPage.startsWith('/admin/notices') ? 'active' : '' %>"><a href="/admin/notices"><i class="fa-solid fa-bullhorn"></i>Announcements</a></li>
                <li class="<%= currentPage.startsWith('/admin/complaints') ? 'active' : '' %>"><a href="/admin/complaints"><i class="fa-solid fa-circle-exclamation"></i> Complaints</a></li>
                <li class="<%= currentPage === '/admin/gallery' ? 'active' : '' %>"><a href="/admin/gallery"><i class="fa-solid fa-images"></i> Gallery</a></li>
                <li class="<%= currentPage === '/admin/devloper' ? 'active' : '' %>"><a href="/admin/devloper"><i class="fa-solid fa-code"></i> Developer</a></li>
                <li class="logout-item"><a href="/admin/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a></li>
            </ul> 
        </nav>

        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light bg-light">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-teal">
                        <i class="fas fa-align-left"></i>
                    </button>
                    <span class="ms-3 fw-bold text-uppercase">Warden Control Panel</span>
                </div>
            </nav>

            <div class="admin-main-body">
                <%- include("../include/flash.ejs") %>
                <%- body -%>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarCollapse').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('active');
        });
    </script>
</body>
</html>