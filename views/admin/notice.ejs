<% layout('/layout/admin-lyout.ejs') -%>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-bullhorn text-teal me-2"></i>Notice Board Management</h2>
        <a href="/admin/notices/new" class="btn btn-teal shadow-sm">
            <i class="fa-solid fa-plus me-1"></i> Add New Announcement
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Date</th>
                        <th>Title</th>
                        <th>Important</th>
                        <th>Status (Active)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let notice of allNotices) { %>
                    <tr>
                        <td class="small text-muted">
                            <%= notice.date.toLocaleDateString('en-GB') %>
                        </td>
                        <td>
                            <span class="fw-semibold"><%= notice.title %></span>
                        </td>
                        <td>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" 
                                    <%= notice.isImportant ? 'checked' : '' %> 
                                    onchange="toggleNotice('<%= notice._id %>', 'important')">
                            </div>
                        </td>
                        <td>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" 
                                    <%= notice.isActive ? 'checked' : '' %> 
                                    onchange="toggleNotice('<%= notice._id %>', 'active')">
                            </div>
                        </td>
                        <td>
                            <form method="POST" action="/admin/notices/<%= notice._id %>?_method=DELETE" class="d-inline">
                                <button class="btn btn-outline-danger btn-sm border-0">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
async function toggleNotice(id, type) {
    try {
        await fetch(`/admin/notices/${id}/toggle?type=${type}`, { method: 'POST' });
        // Optional: Show a small toast message
    } catch (err) {
        alert("Something went wrong!");
    }
}
</script>