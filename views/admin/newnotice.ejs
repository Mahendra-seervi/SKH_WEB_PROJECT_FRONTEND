<% layout('/layout/admin-lyout.ejs') -%>

<div class="container-fluid py-4 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-11">
            
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <h2 class="fw-bold text-teal mb-0">
                    <i class="fa-solid fa-plus-circle me-2"></i>Create New Notice
                </h2>
                <a href="/admin/notices" class="btn btn-outline-secondary btn-sm rounded-pill px-4 align-self-start align-self-md-center">
                    <i class="fa-solid fa-arrow-left me-1"></i> Back to Management
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-body p-3 p-md-5">
                    <form action="/admin/notices" method="POST" class="needs-validation" novalidate>
                        
                        <div class="row g-4 g-lg-5">
                            
                            <div class="col-12 col-lg-8">
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted text-uppercase tracking-wider">Notice Title</label>
                                    <input type="text" name="notice[title]" class="form-control form-control-lg border-2" placeholder="e.g. Hostel Fees Deadline" required>
                                    <div class="invalid-feedback">Title is mandatory.</div>
                                </div>

                                <div class="mb-0">
                                    <label class="form-label fw-bold small text-muted text-uppercase tracking-wider">Notice Description</label>
                                    <textarea name="notice[description]" class="form-control border-2" rows="12" placeholder="Write the complete message here..." required></textarea>
                                    <div class="invalid-feedback">Description cannot be empty.</div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-4">
                                <div class="sticky-lg-top" style="top: 2rem;">
                                    
                                    <div class="mb-4 p-4 rounded-4 border-start border-4 border-teal bg-light shadow-sm">
                                        <h6 class="fw-bold mb-3 d-flex align-items-center">
                                            <i class="fa-solid fa-link me-2 text-teal"></i>Attachment Link
                                        </h6>
                                        <input type="url" name="notice[link]" class="form-control border-2" placeholder="https://drive.google.com/..." required>
                                        <div class="invalid-feedback">Please provide a valid URL.</div>
                                        <p class="form-text mt-2 mb-0 x-small">Students will use this link to download documents.</p>
                                    </div>

                                    <div class="mb-4 p-4 rounded-4 border bg-white shadow-sm">
                                        <h6 class="fw-bold mb-3 d-flex align-items-center">
                                            <i class="fa-solid fa-sliders me-2 text-teal"></i>Notice Settings
                                        </h6>
                                        
                                        <div class="form-check form-switch mb-3 custom-switch-wrapper">
                                            <input class="form-check-input custom-switch" type="checkbox" name="notice[isImportant]" id="imp">
                                            <label class="form-check-label fw-bold text-dark" for="imp">Important Notice</label>
                                        </div>

                                        <div class="form-check form-switch mb-0 custom-switch-wrapper">
                                            <input class="form-check-input custom-switch" type="checkbox" name="notice[isActive]" id="act" checked>
                                            <label class="form-check-label fw-bold text-dark" for="act">Active Status</label>
                                        </div>
                                    </div>

                                    <div class="d-grid pt-2">
                                        <button type="submit" class="btn btn-teal btn-lg py-3 fw-bold rounded-3 shadow-sm">
                                            <i class="fa-solid fa-paper-plane me-2"></i>Publish Notice
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                        </div> </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Common Teal Colors */
    :root {
        --teal-color: #007A83;
    }

    .text-teal { color: var(--teal-color) !important; }
    
    .btn-teal {
        background-color: var(--teal-color);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-teal:hover {
        background-color: #005a61;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(0, 122, 131, 0.3) !important;
    }

    .border-teal { border-color: var(--teal-color) !important; }

    /* Input Focus */
    .form-control:focus {
        border-color: var(--teal-color);
        box-shadow: 0 0 0 0.25rem rgba(0, 122, 131, 0.1);
    }

    /* Switch Styling */
    .custom-switch:checked {
        background-color: var(--teal-color);
        border-color: var(--teal-color);
    }

    .custom-switch-wrapper label {
        cursor: pointer;
        font-size: 0.95rem;
    }

    .tracking-wider { letter-spacing: 0.05rem; }
    .x-small { font-size: 0.75rem; color: #6c757d; }

    /* Fix for PC screen resizing */
    @media (min-width: 992px) {
        .card-body { padding: 4rem !important; }
        /* Prevent content overlap during resizing */
        .col-lg-4 {
            padding-left: 2rem;
        }
    }

    @media (max-width: 991px) {
        .sticky-lg-top {
            position: static !important;
        }
    }
</style>

<script>
(() => {
  'use strict'
  const forms = document.querySelectorAll('.needs-validation')
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault()
        event.stopPropagation()
      }
      form.classList.add('was-validated')
    }, false)
  })
})()
</script>