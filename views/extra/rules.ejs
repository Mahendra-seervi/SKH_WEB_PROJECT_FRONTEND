<% layout('/layout/boilerplate.ejs') -%>

<div class="container py-4 py-md-5">
    <div class="row justify-content-center">
        <div class="col-lg-11 col-xl-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                
                <div class="bg-dark text-white p-4 p-md-5 text-center border-bottom border-teal border-5">
                    <h1 class="fw-bold h3 mb-2">छात्रावास प्रबंध कमेटी द्वारा निर्धारित नियम एवं उपनियम</h1>
                    <p class="lead mb-0 opacity-75 small">सीरवी किसान छात्रावास-पाली</p>
                </div>

                <div class="card-body p-3 p-md-5">
                    
                    <div class="alert alert-danger border-0 shadow-sm mb-5">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>
                        <strong>महत्वपूर्ण:</strong> अनुशासनहीनता करने पर छात्र को तुरंत प्रभाव से निष्कासित (Expelled) कर दिया जाएगा और भविष्य में प्रवेश नहीं दिया जाएगा।
                    </div>

                    <section class="mb-5">
                        <h4 class="fw-bold text-teal mb-4 border-bottom pb-2">
                            <i class="fa-solid fa-user-check me-2"></i> सामान्य आचरण और व्यवहार
                        </h4>
                        <ol class="list-group list-group-flush shadow-sm rounded-3">
                            <li class="list-group-item">1. सभी छात्रों को अनुशासन में रहना होगा।</li>
                            <li class="list-group-item">2. साथी छात्रों, अतिथियों एवं अभिभावकों के साथ शिष्टता का व्यवहार करना अनिवार्य है।</li>
                            <li class="list-group-item">3. छात्रावास के व्यवस्थापक/वार्डन के प्रति हमेशा अच्छा आचरण प्रकट करना अनिवार्य है।</li>
                            <li class="list-group-item">4. परिसर में किसी भी प्रकार की गंदगी नहीं फैलायें, न ही दीवार या फर्नीचर पर कुछ लिखें।</li>
                            <li class="list-group-item">5. बाहर लगे पेड़-पौधों की उचित देखभाल छात्र द्वारा ही की जायेगी।</li>
                            <li class="list-group-item">6. वार्डन की अनुमति के बिना किसी भी प्रकार की सभा का आयोजन न करें।</li>
                        </ol>
                    </section>

                    <section class="mb-5">
                        <h4 class="fw-bold text-danger mb-4 border-bottom pb-2">
                            <i class="fa-solid fa-ban me-2"></i> निषेध (Strictly Prohibited)
                        </h4>
                        <div class="p-3 bg-light rounded-3">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-3 d-flex align-items-start">
                                    <i class="fa-solid fa-circle-xmark text-danger mt-1 me-2"></i>
                                    <span>7. माता-पिता के अलावा किसी भी अन्य व्यक्ति या छात्र को अपने कमरे में ठहराना सख्त मना है। पकड़े जाने पर कठोर कार्रवाई होगी।</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <i class="fa-solid fa-circle-xmark text-danger mt-1 me-2"></i>
                                    <span>8. परिसर में धूम्रपान या किसी भी नशीली वस्तु का सेवन पूर्णतः निषेध है।</span>
                                </li>
                                <li class="mb-0 d-flex align-items-start">
                                    <i class="fa-solid fa-circle-xmark text-danger mt-1 me-2"></i>
                                    <span>9. वार्डन की अनुमति के बिना छात्रावास से बाहर जाना या रात को गाँव/शहर जाना वर्जित है।</span>
                                </li>
                            </ul>
                        </div>
                    </section>

                    <section class="mb-5">
                        <h4 class="fw-bold text-teal mb-4 border-bottom pb-2">
                            <i class="fa-solid fa-calendar-day me-2"></i> दैनिक दिनचर्या और सुविधाएँ
                        </h4>
                        <ul class="list-group list-group-flush small">
                            <li class="list-group-item">10. वार्डन द्वारा दिये गये आदेशों का पूर्ण रूप से पालन करना होगा।</li>
                            <li class="list-group-item">11. सुबह-शाम की इष्टदेव की प्रार्थना में उपस्थित रहना अनिवार्य है।</li>
                            <li class="list-group-item">12. कमरों में टेप-रिकॉर्डर, हीटर, रॉड, प्रेस (Iron) या बिजली के भारी उपकरणों का उपयोग मना है।</li>
                            <li class="list-group-item">13. कमरे की सफाई छात्र को स्वयं करनी होगी। तोड़-फोड़ होने पर हर्जाना छात्र से वसूला जायेगा।</li>
                            <li class="list-group-item">14. दैनिक दिनचर्या में उपयोग होने वाली वस्तुओं (Bedding etc.) की व्यवस्था छात्र स्वयं करेगा।</li>
                            <li class="list-group-item">15. छात्रावास में छात्र को राजस्थानी व हिन्दी भाषा का ही प्रयोग करना होगा।</li>
                            <li class="list-group-item">16. तीन महीने में एक बार अभिभावक का वार्डन/अध्यक्ष से मिलना अनिवार्य है।</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h4 class="fw-bold text-teal mb-4 border-bottom pb-2">
                            <i class="fa-solid fa-file-invoice-dollar me-2"></i> शुल्क और प्रवेश नियम
                        </h4>
                        <div class="row g-3 small">
                            <div class="col-12">
                                <div class="p-3 border rounded bg-white">
                                    <p class="mb-2">17. नियमों में फेरबदल का अधिकार प्रबंध कमेटी के पास सुरक्षित है।</p>
                                    <p class="mb-2">18. छात्रावास छोड़ने की सूचना 15 दिन पहले लिखित में देनी होगी, अन्यथा अग्रिम भोजन शुल्क नहीं लौटेगा।</p>
                                    <p class="mb-2">19. छात्रावास शुल्क हर महीने की 5 तारीख तक जमा करना अनिवार्य है।</p>
                                    <p class="mb-2">20. वार्षिक परीक्षा के 15 दिन बाद छात्र को अपनी कॉशन मनी (Security) वापस लेनी होगी।</p>
                                    <p class="mb-0">21. परिसर में साइकिल/मोटरसाइकिल रखना मना है। अनुमति के बिना रखने पर प्रवेश रद्द हो सकता है।</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="mb-5">
                        <h4 class="fw-bold text-teal mb-4 border-bottom pb-2">
                            <i class="fa-solid fa-user-tie me-2"></i> मुलाकात और वेशभूषा
                        </h4>
                        <ul class="list-group list-group-flush small">
                            <li class="list-group-item">22. माता-पिता/भाई के अलावा किसी भी अन्य मेहमान को ठहराने के लिए अतिरिक्त शुल्क देना होगा।</li>
                            <li class="list-group-item">23. पुस्तकालय का उपयोग नाम मात्र शुल्क और वाई-फाई सुविधा के साथ किया जा सकता है।</li>
                            <li class="list-group-item"><strong>24. वेशभूषा:</strong> छात्र को छात्रावास में साधारण कपड़े (टी-शर्ट, पेंट, शर्ट) और बालों की सिंपल कटिंग (साधारण बाल) रखना अनिवार्य है।</li>
                        </ul>
                    </section>

                    <div class="p-4 rounded-4 mb-5 shadow-sm" style="background-color: #f0fdfa; border: 1px solid #007A83;">
                        <h5 class="fw-bold text-teal d-flex align-items-center">
                            <i class="fa-solid fa-database me-2"></i> लाइफ-टाइम डेटा रिकॉर्ड और सुरक्षा
                        </h5>
                        <p class="small text-dark mb-3">
                            छात्रावास प्रबंधन सभी छात्रों का रिकॉर्ड (जैसे नाम, पिता का नाम, और आचरण) जीवनभर के लिए सुरक्षित रखता है। यह रिकॉर्ड आपके भविष्य में दोबारा प्रवेश (Re-admission) लेने या पुराने छात्र के रूप में सत्यापन (Verification) के लिए एक स्थायी प्रमाण के रूप में काम आता है।
                        </p>
                        
                        <div class="bg-white p-3 rounded-3 border-start border-4 border-teal mb-3">
                            <p class="small mb-0">
                                <i class="fa-solid fa-lock text-teal me-1"></i> 
                                <strong>सुरक्षा का वादा:</strong> आपका संवेदनशील डेटा (जैसे आधार नंबर और पासवर्ड) अत्याधुनिक <strong>Hashing</strong> तकनीक से लॉक है। इसे हॉस्टल का स्टाफ या डेवलपर भी नहीं देख सकते।
                            </p>
                        </div>

                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <span class="small text-muted italic">*अधिक जानकारी के लिए हमारी सुरक्षा नीति पढ़ें।</span>
                            <a href="/privacy" class="btn btn-sm btn-outline-teal rounded-pill px-3">
                                <i class="fa-solid fa-shield-halved me-1"></i> निजता नीति (Privacy Policy) देखें
                            </a>
                        </div>
                    </div>



                    <div class="text-center mt-5">
                        <p class="small text-muted">मैने उपरोक्त सभी नियमों को ध्यानपूर्वक पढ़ लिया है और मैं इनका पालन करने के लिए सहमत हूँ।</p>
                        <div class="d-grid d-md-inline-block gap-2">
                            <a href="/" class="btn btn-teal btn-lg px-5 rounded-pill shadow-sm">स्वीकार है (Home)</a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-teal { color: #007A83 !important; }
    .bg-teal { background-color: #007A83 !important; }
    .btn-teal { background-color: #007A83; color: white; border: none; transition: 0.3s; }
    .btn-teal:hover { background-color: #005a61; color: white; transform: translateY(-2px); }
    .list-group-item { border-left: none; border-right: none; padding: 12px 0; color: #444; }
    .btn-outline-teal {
        border-color: #007A83;
        color: #007A83;
        transition: 0.3s;
    }
    .btn-outline-teal:hover {
        background-color: #007A83;
        color: white;
    }
    .italic { font-style: italic; }
    @media (max-width: 576px) {
        h1 { font-size: 1.2rem !important; }
        .card-body { padding: 1.2rem !important; }
        .btn-lg { width: 100%; }
    }
</style>